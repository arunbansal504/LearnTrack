{
  "rewrites": [
    { "source": "/", "destination": "/landing.html" },
    { "source": "/auth/callback", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/scripts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/styles/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
